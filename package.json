{
  "name": "pihka",
  "version": "0.1.0",
  "description": "Sustainable data publishing platform for digital humanities research",
  "type": "module",
  "scripts": {
    "dev": "browser-sync start --server pihka --files '**/*.js, **/*.css, **/*.html' --no-notify",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "create-sample-db": "node scripts/create-sample-db.js",
    "download-dbs": "node scripts/download-dbs.js",
    "download-world-pmtiles": "node scripts/download-world-pmtiles.js",
    "download-covers": "node scripts/download-covers.js",
    "vendorize": "node scripts/vendorize-deps.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/node": "^25.0.10",
    "browser-sync": "^3.0.2"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "^3.51.2-build4",
    "maplibre-gl": "^5.19.0",
    "preact": "^10.28.3",
    "sql.js": "^1.14.1"
  }
}
